# Server Config
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xcelerate
DB_USER=postgres
DB_PASS=yourpassword

# JWT & Auth
JWT_SECRET=your_jwt_secret_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=your_admin_secret_change_this_in_production

# Email (Gmail SMTP for OTP & Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Xcelerate Academy
SMTP_FROM_EMAIL=noreply@xcelerate.com

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# AWS S3 (for file uploads - videos, notes, assignments)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=xcelerate-uploads
AWS_S3_ENDPOINT=https://xcelerate-uploads.s3.amazonaws.com

# Jitsi Meet (for live classes)
JITSI_SERVER_URL=https://meet.jitsi
JITSI_APP_ID=xcelerate

# Twilio (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890

# Frontend URLs
FRONTEND_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5173/admin

# Session & Redis (for caching, sessions)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug

# File Upload Limits
MAX_FILE_SIZE_MB=1000
MAX_VIDEO_SIZE_MB=2000
